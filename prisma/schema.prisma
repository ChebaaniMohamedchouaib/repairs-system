generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TECHNICIAN
}

enum RepairStatus {
  PENDING
  DIAGNOSING
  WAITING_PARTS
  READY
  DELIVERED
  CANCELLED
}

model User {
  id           String         @id @default(uuid()) @db.Uuid
  fullName     String
  username     String         @unique
  passwordHash String
  role         Role           @default(TECHNICIAN)
  createdAt    DateTime       @default(now())
  repairs      RepairTicket[] 
}

model Customer {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  phone     String         @unique
  createdAt DateTime       @default(now())
  tickets   RepairTicket[] 
}

model RepairTicket {
  id               Int            @id @default(autoincrement())
  customerId       String         @db.Uuid
  technicianId     String?        @db.Uuid 
  deviceModel      String
  imei             String?
  passcode         String?
  issueDescription String
  techNotes        String?
  estimatedPrice   Decimal?       @db.Decimal(10, 2)
  deposit          Decimal        @default(0) @db.Decimal(10, 2)
  status           RepairStatus   @default(PENDING)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  price            Float        @default(0.0)
  customer         Customer       @relation(fields: [customerId], references: [id])
  technician       User?          @relation(fields: [technicianId], references: [id])
  usedParts        TicketPart[]   
}

model SparePart {
  id               Int            @id @default(autoincrement())
  name             String
  compatibleModels String?
  stockQuantity    Int            @default(0)
  costPrice        Decimal?       @db.Decimal(10, 2)
  sellingPrice     Decimal?       @db.Decimal(10, 2)
  ticketParts      TicketPart[] 
}

model TicketPart {
  id           Int          @id @default(autoincrement())
  ticketId     Int
  partId       Int
  quantity     Int          @default(1)
  priceApplied Decimal?     @db.Decimal(10, 2)
  
  ticket       RepairTicket @relation(fields: [ticketId], references: [id])
  part         SparePart    @relation(fields: [partId], references: [id])
}